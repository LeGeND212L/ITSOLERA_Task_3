NODE_ENV=production
PORT=5000

# Backend URL (used by frontend for API calls)
BACKEND_URL=https://your-backend.vercel.app

# Database Configuration
# Use your MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/medical-store?retryWrites=true&w=majority
# Optional fallback database URI for high availability
MONGODB_URI_FALLBACK=

# JWT Secret (if using JWT authentication)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# CORS Configuration (comma-separated list for multiple origins)
CORS_ORIGINS=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# Startup Configuration
# AUTO_SEED_ON_STARTUP should be FALSE in production
AUTO_SEED_ON_STARTUP=false
# ENSURE_ADMIN_ON_STARTUP creates/updates default admin if true
ENSURE_ADMIN_ON_STARTUP=true
# Allow server to start even if DB is not available
ALLOW_SERVER_WITHOUT_DB=false

# Default Admin Credentials
# Change these credentials AFTER first login to production
DEFAULT_ADMIN_USERNAME=Admin
DEFAULT_ADMIN_PASSWORD=Admin123@

# Optional: Log Level Configuration
LOG_LEVEL=error

