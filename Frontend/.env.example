# Frontend Environment Configuration for Production

# API Base URL pointing to your backend
# Development: http://localhost:5000/api
# Production: https://your-backend.vercel.app/api
VITE_API_BASE_URL=https://your-backend.vercel.app/api

# Application Environment Identifier
VITE_APP_ENV=production

# Optional: Application name/title
VITE_APP_NAME=Medical Store Management System

# Optional: Custom API timeout (in milliseconds)
VITE_API_TIMEOUT=15000

